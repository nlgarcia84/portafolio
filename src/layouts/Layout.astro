---
const {
  title = 'Portfolio Astro',
  description = 'Portfolio personal creado con Astro y TypeScript.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #000;
    --bg-elevated: #111;
    --panel: rgba(255, 255, 255, 0.04);
    --panel-strong: rgba(255, 255, 255, 0.08);
    --text: #ededed;
    --muted: #888;
    --accent: #fff;
    --border: rgba(255, 255, 255, 0.06);
    --border-strong: rgba(255, 255, 255, 0.1);
    --radius: 12px;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(
        ellipse 80% 50% at 50% -20%,
        rgba(196, 181, 253, 0.15),
        transparent
      ),
      var(--bg);
    color: var(--text);
    font-family:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif;
  }

  body {
    position: relative;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  body::before {
    content: '';
    position: fixed;
    inset: -100%;
    width: 300%;
    height: 300%;
    background:
      radial-gradient(
        circle at 20% 30%,
        rgba(196, 181, 253, 0.15),
        transparent 45%
      ),
      radial-gradient(
        circle at 80% 70%,
        rgba(167, 139, 250, 0.12),
        transparent 40%
      ),
      radial-gradient(
        circle at 40% 80%,
        rgba(139, 92, 246, 0.1),
        transparent 45%
      ),
      radial-gradient(
        circle at 70% 20%,
        rgba(124, 58, 237, 0.08),
        transparent 50%
      );
    animation: morph 18s ease-in-out infinite alternate;
    z-index: -1;
    pointer-events: none;
  }

  @keyframes morph {
    0%   { transform: translate(-5%, -5%) scale(1); }
    25%  { transform: translate(15%, -10%) scale(1.1); }
    50%  { transform: translate(-10%, 15%) scale(0.9); }
    75%  { transform: translate(-15%, -8%) scale(1.05); }
    100% { transform: translate(10%, 10%) scale(1); }
  }

  a {
    color: inherit;
  }
</style>
