---
import Layout from '../layouts/Layout.astro';
import normanImage from '../assets/norman.png';

type Project = {
  title: string;
  description: string;
  stack: string[];
  href: string;
};

type Skill = {
  name: string;
  icon: string;
};

const skills: Skill[] = [
  { name: 'HTML5', icon: 'devicon-html5-plain' },
  { name: 'CSS3', icon: 'devicon-css3-plain' },
  { name: 'JavaScript', icon: 'devicon-javascript-plain' },
  { name: 'React', icon: 'devicon-react-original' },
  { name: 'Node.js', icon: 'devicon-nodejs-plain' },
  { name: 'Express', icon: 'devicon-express-original' },
  { name: 'MySQL', icon: 'devicon-mysql-original' },
  { name: 'MongoDB', icon: 'devicon-mongodb-plain' },
  { name: 'Git/GitHub', icon: 'devicon-github-original' },
  { name: 'REST APIs', icon: 'devicon-postman-plain' },
  { name: 'Responsive Design', icon: 'devicon-chrome-plain' },
  { name: 'Agile', icon: 'devicon-jira-plain' },
  { name: 'GitHub Copilot', icon: 'devicon-github-original' },
  { name: 'OpenCode', icon: 'devicon-vscode-plain' },
];

const projects: Project[] = [
  {
    title: 'Web Corporativa — RC Technology',
    description:
      'Web corporativa desarrollada durante las prácticas como Fullstack Developer Intern. Maquetación con Astro y Tailwind, backend con Supabase.',
    stack: ['Astro', 'Tailwind', 'Supabase', 'JavaScript', 'Git'],
    href: 'https://www.rctechnology.es/',
  },
  {
    title: 'Roomy — App de reservas',
    description:
      'Proyecto final de DAW en grupo de 4 desarrolladores. Junto con un compañero me encargué del frontend con Next.js y Tailwind. Aplicación web de reserva de salas de reuniones con backend en Spring Boot y Supabase.',
    stack: ['Next.js', 'Tailwind', 'Supabase', 'Spring Boot', 'Java'],
    href: 'https://reservesapp-frontend.vercel.app/',
  },
];
---

<Layout
  title="Norman Leyva | Fullstack Developer"
  description="Portfolio de Norman Leyva García — Grado Superior en Desarrollo de Aplicaciones Web. React, Node.js, JavaScript, y más."
>
  <main class="mx-auto grid max-w-[1100px] gap-6 px-6 py-16 md:py-20">
    <div class="flex justify-end gap-2">
      <button class="lang-btn cursor-pointer rounded-md border border-[rgba(255,255,255,0.08)] bg-transparent px-3 py-1 text-xs font-medium text-muted transition-colors hover:border-lila/40 hover:text-lila-light data-[active=true]:border-lila/40 data-[active=true]:text-lila-light" data-lang="es" onclick="switchLang('es')">ES</button>
      <button class="lang-btn cursor-pointer rounded-md border border-[rgba(255,255,255,0.08)] bg-transparent px-3 py-1 text-xs font-medium text-muted transition-colors hover:border-lila/40 hover:text-lila-light data-[active=true]:border-lila/40 data-[active=true]:text-lila-light" data-lang="ca" onclick="switchLang('ca')">CA</button>
      <button class="lang-btn cursor-pointer rounded-md border border-[rgba(255,255,255,0.08)] bg-transparent px-3 py-1 text-xs font-medium text-muted transition-colors hover:border-lila/40 hover:text-lila-light data-[active=true]:border-lila/40 data-[active=true]:text-lila-light" data-lang="en" onclick="switchLang('en')">EN</button>
    </div>

    <section
      class="relative isolate grid min-h-[380px] grid-cols-1 gap-8 overflow-hidden rounded-[12px] bg-transparent p-8 md:grid-cols-[1fr_auto] md:p-16"
      style={`--portrait-src: url(${normanImage.src})`}
    >
      <div class="hero-bg absolute inset-[-40px] -z-10 rounded-none"
        style="background: linear-gradient(135deg, rgba(0,0,0,0.94) 0%, rgba(0,0,0,0.8) 50%, rgba(0,0,0,0.55) 100%), var(--portrait-src); background-position: center; background-size: cover; filter: grayscale(1) blur(2px);">
      </div>

      <div class="flex min-w-0 flex-col justify-center">
        <p class="mb-4 text-[0.75rem] font-medium uppercase tracking-[0.12em] text-lila" data-i18n="hero.eyebrow">
          <span class="hl">Fullstack Developer</span> · Barcelona
        </p>
        <h1 class="m-0 max-w-[14ch] text-[clamp(2.2rem,5vw,4.5rem)] font-semibold leading-[1.05] tracking-[-0.03em]" data-i18n="hero.title">
          Norman Leyva
        </h1>
        <p class="mt-5 max-w-[58ch] text-[1.05rem] leading-relaxed text-muted" data-i18n="hero.lead">
          Junior Fullstack Web Developer con transición a tecnología en 2022.
          Experiencia en frontend y backend con <span class="hl">JavaScript</span>,
          <span class="hl">React</span>, Node.js y APIs REST. Formación en
          Marketing y ADE con fuerte enfoque en el usuario.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="rounded-full bg-white px-5 py-2.5 text-sm font-medium text-black no-underline opacity-100 transition-opacity hover:opacity-80" href="#proyectos" data-i18n="hero.btn.projects">Ver proyectos</a>
          <a class="rounded-full border border-[rgba(255,255,255,0.1)] bg-transparent px-5 py-2.5 text-sm font-medium text-text no-underline transition-all hover:border-white/25 hover:bg-white/5" href="#contacto" data-i18n="hero.btn.contact">Contactar</a>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div class="rounded-[12px] border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.04)] p-6 transition-colors duration-200 hover:border-lila/25">
        <h2 class="m-0 mb-3 text-[1.1rem] font-semibold" data-i18n="about.title">Sobre mí</h2>
        <p data-i18n="about.p1">
          <span class="hl">Grado Superior en Desarrollo de Aplicaciones Web (DAW, 2026)</span>
          cursado en el Institut Obert de Catalunya.
        </p>
        <p class="mt-3 leading-relaxed text-muted" data-i18n="about.p2">
          Licenciado en ADE y Marketing Digital, aunque finalmente no ejercí.
          Me decanté por el sector tech cursando un bootcamp en Ironhack y
          especializándome después en desarrollo web. Mi formación de
          gestión y marketing me aporta una visión estratégica y centrada en el
          usuario.
        </p>
        <p class="mt-3 leading-relaxed text-muted" data-i18n="about.p3">
          Mis <span class="hl">42 años</span> me han desarrollado habilidades
          blandas como comunicación, trabajo en equipo, resolución de problemas
          y adaptabilidad.
        </p>
      </div>

      <div class="rounded-[12px] border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.04)] p-6 transition-colors duration-200 hover:border-lila/25">
        <h2 class="m-0 mb-3 text-[1.1rem] font-semibold" data-i18n="stack.title">Stack tecnológico</h2>
        <ul class="m-0 mt-4 flex list-none flex-wrap gap-2 p-0">
          {skills.map((skill) => (
            <li class="inline-flex items-center gap-1.5 rounded-md border border-lila/20 bg-lila/10 px-2.5 py-1 text-sm font-medium text-lila-light">
              <i class={skill.icon}></i> {skill.name}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="proyectos" class="rounded-[12px] border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.04)] p-6 transition-colors duration-200 hover:border-lila/25">
      <h2 class="m-0 mb-3 text-[1.1rem] font-semibold" data-i18n="projects.title">Proyectos</h2>
      <div class="mt-2 grid grid-cols-1 gap-4 md:grid-cols-2">
        {
          projects.map((project) => (
            <article class="rounded-[12px] border border-lila/10 bg-white/[0.02] p-5 transition-colors duration-200 hover:border-lila/25">
              <h3 class="m-0 mb-1.5 text-[1rem] font-semibold">{project.title}</h3>
              <p class="m-0 text-[0.9rem] leading-relaxed text-muted">{project.description}</p>
              <ul class="small m-0 mt-3 flex list-none flex-wrap gap-2 p-0">
                {project.stack.map((item) => (
                  <li class="inline-flex items-center gap-1.5 rounded-md border border-lila/20 bg-lila/10 px-2.5 py-1 text-sm font-medium text-lila-light">{item}</li>
                ))}
              </ul>
              <a class="mt-3 inline-block text-[0.85rem] font-medium text-muted no-underline transition-colors hover:text-lila-light" href={project.href} target="_blank" rel="noopener" data-i18n="projects.link">Visitar proyecto</a>
            </article>
          ))
        }
      </div>
    </section>

    <section id="contacto" class="flex flex-wrap items-center justify-between gap-4 rounded-[12px] border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.04)] p-6 transition-colors duration-200 hover:border-lila/25">
      <div>
        <h2 class="m-0 mb-3 text-[1.1rem] font-semibold" data-i18n="contact.title">Contacto</h2>
        <p class="m-0 max-w-[60ch] leading-relaxed text-muted">
          <span data-i18n="contact.text">¿Quieres contactarme? Escríbeme a</span>
          <a class="text-muted no-underline transition-colors hover:text-lila-light" href="mailto:nleyvagarcia1@icloud.com">nleyvagarcia1@icloud.com</a>.
        </p>
      </div>
      <div class="flex gap-3">
        <a class="rounded-md border border-[rgba(255,255,255,0.06)] px-3 py-2 text-sm font-medium text-muted no-underline transition-colors hover:border-lila/40 hover:text-lila-light" href="https://linkedin.com/in/norman-leyva" target="_blank" rel="noopener">LinkedIn</a>
        <a class="rounded-md border border-[rgba(255,255,255,0.06)] px-3 py-2 text-sm font-medium text-muted no-underline transition-colors hover:border-lila/40 hover:text-lila-light" href="https://github.com/nlgarcia84" target="_blank" rel="noopener">GitHub</a>
      </div>
    </section>
  </main>
</Layout>

<script>
  import translations from '../i18n/translations.js';

  function getDefaultLang() {
    const stored = localStorage.getItem('lang');
    if (stored) return stored;
    const browserLang = navigator.language?.slice(0, 2);
    if (['es', 'ca', 'en'].includes(browserLang)) return browserLang;
    return 'es';
  }

  let currentLang = getDefaultLang();

  function switchLang(lang) {
    currentLang = lang;
    localStorage.setItem('lang', lang);
    applyLang(lang);
    updateLangButtons(lang);
  }

  function applyLang(lang) {
    const t = translations[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n;
      if (t[key]) {
        if (key === 'hero.lead') {
          const hl = document.querySelector('.hero-lead-highlight');
          el.innerHTML = t['hero.lead1'] + ' ' + t['hero.lead2'] + ' ' + (hl ? hl.outerHTML : 'JavaScript, React') + t['hero.lead3'];
        } else if (key === 'about.p1') {
          el.innerHTML = t[key].replace('Grado Superior en Desarrollo de Aplicaciones Web (DAW, 2026)', '<span class="hl">Grado Superior en Desarrollo de Aplicaciones Web (DAW, 2026)</span>');
        } else if (key === 'about.p3') {
          el.innerHTML = t[key].replace('42 años', '<span class="hl">42 años</span>');
        } else if (key === 'hero.eyebrow') {
          el.innerHTML = t[key].replace('Fullstack Developer', '<span class="hl">Fullstack Developer</span>');
        } else {
          el.textContent = t[key];
        }
      }
    });
    document.title = t['meta.title'];
    document.querySelector('meta[name="description"]').content = t['meta.desc'];
  }

  function updateLangButtons(lang) {
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.dataset.active = btn.dataset.lang === lang ? 'true' : 'false';
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    applyLang(currentLang);
    updateLangButtons(currentLang);
  });

  window.switchLang = switchLang;
</script>
