---
import Layout from '../layouts/Layout.astro';
import normanImage from '../assets/norman.png';

type Project = {
  title: string;
  description: string;
  stack: string[];
  href: string;
};

type Skill = {
  name: string;
  icon: string;
};

const skills: Skill[] = [
  { name: 'HTML5', icon: 'devicon-html5-plain' },
  { name: 'CSS3', icon: 'devicon-css3-plain' },
  { name: 'JavaScript', icon: 'devicon-javascript-plain' },
  { name: 'React', icon: 'devicon-react-original' },
  { name: 'Node.js', icon: 'devicon-nodejs-plain' },
  { name: 'Express', icon: 'devicon-express-original' },
  { name: 'MySQL', icon: 'devicon-mysql-original' },
  { name: 'MongoDB', icon: 'devicon-mongodb-plain' },
  { name: 'Git/GitHub', icon: 'devicon-github-original' },
  { name: 'REST APIs', icon: 'devicon-postman-plain' },
  { name: 'Responsive Design', icon: 'devicon-chrome-plain' },
  { name: 'Agile', icon: 'devicon-jira-plain' },
  { name: 'GitHub Copilot', icon: 'devicon-github-original' },
  { name: 'OpenCode', icon: 'devicon-vscode-plain' },
];

const projects: Project[] = [
  {
    title: 'Web Corporativa — RC Technology',
    description:
      'Web corporativa desarrollada durante las prácticas como Fullstack Developer Intern. Maquetación con Astro y Tailwind, backend con Supabase.',
    stack: ['Astro', 'Tailwind', 'Supabase', 'JavaScript', 'Git'],
    href: 'https://www.rctechnology.es/',
  },
  {
    title: 'Roomy — App de reservas',
    description:
      'Proyecto final de DAW. Aplicación web de reserva de salas de reuniones con frontend en Next.js + Tailwind, backend en Spring Boot y Supabase.',
    stack: ['Next.js', 'Tailwind', 'Supabase', 'Spring Boot', 'Java'],
    href: 'https://reservesapp-frontend.vercel.app/',
  },
];
---

<Layout
  title="Norman Leyva | Fullstack Developer"
  description="Portfolio de Norman Leyva García — Grado Superior en Desarrollo de Aplicaciones Web. React, Node.js, JavaScript, y más."
>
  <main class="page">
    <section
      class="hero card"
      style={`--portrait-src: url(${normanImage.src})`}
    >
      <div class="hero-copy">
        <p class="eyebrow">Fullstack Developer · Barcelona</p>
        <h1>Norman Leyva</h1>
        <p class="lead">
          Junior Fullstack Web Developer con transición a tecnología en 2022.
          Experiencia en frontend y backend con JavaScript, React, Node.js y
          APIs REST. Formación en Marketing y ADE con fuerte enfoque en el
          usuario.
        </p>
        <div class="actions">
          <a class="primary" href="#proyectos">Ver proyectos</a>
          <a class="secondary" href="#contacto">Contactar</a>
        </div>
      </div>
    </section>

    <section class="grid">
      <div class="card">
        <h2>Sobre mí</h2>
        <p>
          <strong>Grado Superior en Desarrollo de Aplicaciones Web (DAW, 2026)</strong>
          con experiencia en frontend y backend.
        </p>
        <p>
          Tras una década en atención al cliente en <strong>Adeslas</strong>,
          di el salto a la tecnología cursando un bootcamp en
          <strong>Ironhack</strong> y especializándome después en desarrollo
          web. Mi background en <strong>Marketing y ADE</strong> me aporta una
          visión estratégica y centrada en el usuario.
        </p>
        <p>
          Mis <strong>42 años</strong> me han desarrollado habilidades blandas
          como <strong>comunicación, trabajo en equipo, resolución de problemas
          y adaptabilidad</strong>.
        </p>
      </div>

      <div class="card">
        <h2>Stack tecnológico</h2>
        <ul class="chips" aria-label="Habilidades">
          {skills.map((skill) => (
            <li><i class={skill.icon}></i> {skill.name}</li>
          ))}
        </ul>
      </div>
    </section>

    <section id="proyectos" class="card">
      <h2>Proyectos</h2>
      <div class="projects">
        {
          projects.map((project) => (
            <article>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <ul
                class="chips small"
                aria-label={`Tecnologías para ${project.title}`}
              >
                {project.stack.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <a href={project.href} target="_blank" rel="noopener">Visitar proyecto</a>
            </article>
          ))
        }
      </div>
    </section>

    <section id="contacto" class="card contact">
      <div>
        <h2>Contacto</h2>
        <p>
          ¿Quieres contactarme? Escríbeme a
          <a href="mailto:nleyvagarcia1@icloud.com">nleyvagarcia1@icloud.com</a>.
        </p>
      </div>
      <div class="contact-links">
        <a href="https://linkedin.com/in/norman-leyva" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/nlgarcia84" target="_blank" rel="noopener">GitHub</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    width: min(1100px, calc(100% - 3rem));
    margin: 0 auto;
    padding: 4rem 0 5rem;
    display: grid;
    gap: 1.5rem;
  }

  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 2rem;
    padding: clamp(2rem, 5vw, 4rem);
    min-height: 380px;
    border-radius: var(--radius);
    background: transparent;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: -40px;
    background:
      linear-gradient(
        135deg,
        rgba(0, 0, 0, 0.94) 0%,
        rgba(0, 0, 0, 0.8) 50%,
        rgba(0, 0, 0, 0.55) 100%
      ),
      var(--portrait-src);
    background-position: center;
    background-size: cover;
    filter: grayscale(1) blur(2px);
    z-index: -1;
    border-radius: 0;
  }

  .hero-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .eyebrow {
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    color: #a78bfa;
    font-weight: 500;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    line-height: 1.05;
    max-width: 14ch;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .lead,
  .card p {
    color: var(--muted);
    line-height: 1.7;
    font-size: 1rem;
  }

  .lead {
    max-width: 58ch;
    margin: 1.2rem 0 0;
    font-size: 1.05rem;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .actions a {
    text-decoration: none;
  }

  .primary {
    padding: 0.7rem 1.4rem;
    border-radius: 999px;
    font-weight: 500;
    font-size: 0.9rem;
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
    color: #fff;
    border: none;
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .primary:hover {
    opacity: 0.9;
    transform: scale(1.02);
  }

  .secondary {
    padding: 0.7rem 1.4rem;
    border-radius: 999px;
    font-weight: 500;
    font-size: 0.9rem;
    color: #c4b5fd;
    border: 1px solid rgba(167, 139, 250, 0.3);
    background: rgba(167, 139, 250, 0.06);
    transition:
      border-color 150ms ease,
      background 150ms ease,
      transform 150ms ease;
  }

  .secondary:hover {
    border-color: rgba(167, 139, 250, 0.6);
    background: rgba(167, 139, 250, 0.12);
    transform: scale(1.02);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: border-color 200ms ease;
  }

  .card:hover {
    border-color: rgba(167, 139, 250, 0.25);
  }

  h2 {
    margin: 0 0 0.75rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .chips {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chips li {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
    background: rgba(167, 139, 250, 0.08);
    border: 1px solid rgba(167, 139, 250, 0.15);
    font-size: 0.85rem;
    font-weight: 450;
    color: #c4b5fd;
  }

  .projects {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .projects article {
    padding: 1.25rem;
    border-radius: var(--radius);
    background: rgba(167, 139, 250, 0.03);
    border: 1px solid rgba(167, 139, 250, 0.1);
    transition: border-color 200ms ease;
  }

  .projects article:hover {
    border-color: rgba(167, 139, 250, 0.25);
  }

  .projects h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .projects p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  .projects a,
  .contact a {
    display: inline-block;
    margin-top: 0.8rem;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    transition: color 150ms ease;
  }

  .projects a:hover,
  .contact a:hover {
    color: #c4b5fd;
  }

  .chips li i {
    font-size: 1.1rem;
    line-height: 1;
  }

  .small {
    margin-top: 0.8rem;
  }

  .contact {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .contact p {
    max-width: 60ch;
    margin: 0;
  }

  .contact-links {
    display: flex;
    gap: 0.75rem;
  }

  .contact-links a {
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    border: 1px solid var(--border);
    text-decoration: none;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }

  .contact-links a:hover {
    color: #c4b5fd;
    border-color: rgba(167, 139, 250, 0.4);
  }

  @media (max-width: 800px) {
    .page {
      padding: 2rem 0 3rem;
    }

    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .grid,
    .projects {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 100%;
    }
  }
</style>
